{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "mitre_mappings",
    "description": "One mapping = one technique observed in one session, with supporting evidence. References attack_sessions; detection_evidence[] embedded.",
    "required": ["mapping_id", "technique_id", "technique_name", "tactic", "related_session", "confidence_score", "created_at", "updated_at"],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "mapping_id": { "bsonType": "string", "pattern": "^map_[0-9A-Z]{26}$" },
      "technique_id": { "bsonType": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$", "description": "MITRE ATT&CK technique/sub-technique id." },
      "technique_name": { "bsonType": "string" },
      "tactic": { "enum": ["reconnaissance", "resource_development", "initial_access", "execution", "persistence", "privilege_escalation", "defense_evasion", "credential_access", "discovery", "lateral_movement", "collection", "command_and_control", "exfiltration", "impact"] },
      "description": { "bsonType": "string" },
      "confidence_score": { "bsonType": "double", "minimum": 0, "maximum": 1 },
      "related_session": { "bsonType": "string", "description": "References attack_sessions.session_id." },
      "related_actor": { "bsonType": ["string", "null"], "description": "References threat_actors.actor_id." },
      "detection_evidence": {
        "bsonType": "array",
        "description": "Embedded evidence supporting the mapping.",
        "items": {
          "bsonType": "object", "additionalProperties": false, "required": ["type", "value"],
          "properties": {
            "type": { "enum": ["command", "file", "network", "auth", "signature"] },
            "value": { "bsonType": "string" },
            "ts": { "bsonType": ["date", "null"] }
          }
        }
      },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" }
    }
  }
}
