{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "active_environments",
    "description": "Currently-live deception instances actively engaging an attacker. TTL on retired/expired rows. References generated_environments + the live session.",
    "required": ["environment_id", "generated_environment_ref", "session_ref", "status", "started_at", "expires_at", "created_at", "updated_at"],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "environment_id": { "bsonType": "string", "pattern": "^env_[0-9A-Z]{26}$", "description": "Same id as the generated environment it activates." },
      "generated_environment_ref": { "bsonType": "string", "description": "References generated_environments.environment_id." },
      "session_ref": { "bsonType": "string", "description": "References attack_sessions.session_id." },
      "actor_ref": { "bsonType": ["string", "null"] },
      "status": { "enum": ["active", "idle", "retiring", "retired"] },
      "container_id": { "bsonType": ["string", "null"], "description": "Runtime container/handle id." },
      "endpoint": { "bsonType": ["string", "null"], "description": "host:port the attacker is redirected to." },
      "engagement_seconds": { "bsonType": "double", "minimum": 0 },
      "started_at": { "bsonType": "date" },
      "last_activity_at": { "bsonType": ["date", "null"] },
      "expires_at": { "bsonType": "date", "description": "TTL boundary for auto-teardown of retired instances." },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" }
    }
  }
}
