{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "users",
    "description": "SOC user accounts. password_hash and mfa_secret are field-level encrypted (see 06_security_best_practices.md).",
    "required": ["user_id", "username", "email", "password_hash", "status", "role_refs", "mfa_enabled", "created_at", "updated_at"],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "user_id": { "bsonType": "string", "pattern": "^usr_[0-9A-Z]{26}$", "description": "Business key (prefixed ULID), unique." },
      "username": { "bsonType": "string", "minLength": 3, "maxLength": 64 },
      "email": { "bsonType": "string", "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" },
      "password_hash": { "bsonType": "string", "description": "Argon2id hash; encrypted at rest." },
      "status": { "enum": ["active", "disabled", "locked", "pending"], "description": "Account lifecycle state." },
      "mfa_enabled": { "bsonType": "bool" },
      "mfa_secret": { "bsonType": "string", "description": "TOTP secret, field-encrypted. Optional until mfa_enabled." },
      "role_refs": { "bsonType": "array", "minItems": 1, "items": { "bsonType": "string", "pattern": "^role_[a-z_]+$" }, "description": "References roles.role_id (RBAC)." },
      "analyst_profile_ref": { "bsonType": ["string", "null"], "description": "References analyst_profiles.user_id when this user is an analyst." },
      "last_login_at": { "bsonType": ["date", "null"] },
      "failed_login_count": { "bsonType": "int", "minimum": 0 },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" }
    }
  }
}
