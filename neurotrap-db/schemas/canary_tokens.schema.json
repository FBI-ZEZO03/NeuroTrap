{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "canary_tokens",
    "description": "Thinkst-style canarytoken giving out-of-band alerts when used. Distinct from honey_tokens by its external callback channel. trigger_events[] embedded.",
    "required": ["token_id", "canary_type", "alert_channel", "active", "triggered", "created_at", "updated_at"],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "token_id": { "bsonType": "string", "pattern": "^ctok_[0-9A-Z]{26}$" },
      "environment_ref": { "bsonType": ["string", "null"], "description": "References generated_environments.environment_id (null if global)." },
      "canary_type": { "enum": ["dns", "http_url", "aws_key", "doc", "qr", "smtp", "wireguard"] },
      "trigger_value": { "bsonType": "string", "description": "The unique token string/host that fires the callback." },
      "alert_channel": { "enum": ["email", "slack", "telegram", "webhook"] },
      "active": { "bsonType": "bool" },
      "triggered": { "bsonType": "bool" },
      "trigger_count": { "bsonType": "int", "minimum": 0 },
      "trigger_events": { "bsonType": "array", "items": { "bsonType": "object", "additionalProperties": false, "required": ["ts", "source_ip"], "properties": { "ts": { "bsonType": "date" }, "source_ip": { "bsonType": "string" }, "user_agent": { "bsonType": "string" }, "alert_ref": { "bsonType": ["string", "null"] } } } },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" }
    }
  }
}
