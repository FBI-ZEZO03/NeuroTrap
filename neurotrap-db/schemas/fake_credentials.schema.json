{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "fake_credentials",
    "description": "Planted decoy credentials. secret_enc is field-level encrypted (CSFLE). use_detected flips when the credential is observed in a session, enabling burn-on-use detection.",
    "required": ["credential_id", "environment_ref", "username", "secret_enc", "credential_type", "use_detected", "created_at", "updated_at"],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "credential_id": { "bsonType": "string", "pattern": "^fcred_[0-9A-Z]{26}$" },
      "environment_ref": { "bsonType": "string", "description": "References generated_environments.environment_id." },
      "username": { "bsonType": "string" },
      "secret_enc": { "bsonType": "string", "description": "Encrypted password/key/token value." },
      "credential_type": { "enum": ["password", "ssh_key", "api_key", "aws_key", "db_password", "jwt"] },
      "planted_location": { "bsonType": "string", "description": "Where it was seeded (path, env var, file)." },
      "use_detected": { "bsonType": "bool", "description": "True once the credential is seen used by an attacker." },
      "use_events": { "bsonType": "array", "items": { "bsonType": "object", "additionalProperties": false, "required": ["ts", "session_ref"], "properties": { "ts": { "bsonType": "date" }, "session_ref": { "bsonType": "string" }, "source_ip": { "bsonType": "string" } } } },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" }
    }
  }
}
